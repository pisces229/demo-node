{
  "name": "demo-node",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "^22.18.0",
    "pnpm": "^10.30.3"
  },
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "husky": "^9.1.7",
    "lefthook": "^2.1.3",
    "lint-staged": "^16.3.2"
  },
  "scripts": {
    "app1:lint": "pnpm -C app1 run lint",
    "app2:lint": "pnpm -C app2 run lint",
    "app1:format": "pnpm -C app1 run format",
    "app2:format": "pnpm -C app2 run format"
  },
  "lint-staged": {
    "app1/**/*.{js,ts}": [
      "pnpm -C app1 run lint",
      "pnpm -C app1 run format"
    ],
    "app2/**/*.{js,ts}": [
      "pnpm -C app2 run lint",
      "pnpm -C app2 run format"
    ],
    "**/*.{cs}": [
      "dotnet format --include"
    ]
  }
}
